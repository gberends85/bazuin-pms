# ================================================================
# Autostalling De Bazuin — Omgevingsvariabelen
# Kopieer naar .env en vul alle waarden in
# ================================================================

# ── Database ────────────────────────────────────────────────────
DATABASE_URL=postgresql://bazuin:VERVANG_WACHTWOORD@localhost:5432/bazuin_pms

# ── JWT Secrets (genereer met: openssl rand -base64 48) ─────────
JWT_SECRET=VERVANG_MET_LANGE_WILLEKEURIGE_STRING_MIN_48_TEKENS
JWT_REFRESH_SECRET=VERVANG_MET_ANDERE_LANGE_WILLEKEURIGE_STRING

# ── Stripe ──────────────────────────────────────────────────────
# Vind je Stripe keys op: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_VERVANG_DIT
STRIPE_PUBLISHABLE_KEY=pk_live_VERVANG_DIT
# Webhook secret: Dashboard → Developers → Webhooks → jouw endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_VERVANG_DIT

# ── E-mail (SMTP) ───────────────────────────────────────────────
# Gebruik bijv. Mailgun, Brevo, of je eigen mailserver
SMTP_HOST=smtp.jouwprovider.nl
SMTP_PORT=587
SMTP_USER=info@autostallingdebazuin.nl
SMTP_PASS=VERVANG_MET_EMAIL_WACHTWOORD
EMAIL_FROM_NAME=Autostalling De Bazuin
EMAIL_FROM_ADDRESS=info@autostallingdebazuin.nl

# ── Applicatie URLs ─────────────────────────────────────────────
# Production:
FRONTEND_BOOKING_URL=https://parkeren-harlingen.nl
FRONTEND_ADMIN_URL=https://admin.autostallingdebazuin.nl
API_URL=https://api.autostallingdebazuin.nl
# Development (uncomment):
# FRONTEND_BOOKING_URL=http://localhost:3000
# FRONTEND_ADMIN_URL=http://localhost:3002
# API_URL=http://localhost:3001

# ── Server ──────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
# NODE_ENV=development

# ── Frontend variabelen (ook nodig bij bouwen) ───────────────────
# Stripe publieke sleutel voor checkout in de browser
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_VERVANG_DIT
NEXT_PUBLIC_API_URL=https://api.autostallingdebazuin.nl/api/v1
